{
  "name": "@nexus/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate --schema=../../packages/database/prisma/schema.prisma && tsc",
    "prestart": "cd ../../packages/database && npx prisma migrate deploy",
    "start": "node dist/index.js",
    "start:prod": "cd ../../packages/database && npx prisma migrate deploy && cd ../../apps/api && NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@google/generative-ai": "^0.24.1",
    "@nexus/database": "*",
    "@nexus/shared": "*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "amazon-sp-api": "^1.2.1",
    "bullmq": "^5.76.2",
    "cloudinary": "^2.10.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jszip": "^3.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0"
  }
}
