# ── Amazon publish gating (C.6) ─────────────────────────────────────
# Master switch for the Amazon listing publish path. Default false:
# every wizard /submit attempt for an Amazon channel is logged in
# ChannelPublishAttempt with outcome='gated' and short-circuited
# before any HTTP. Set true once dryRun → sandbox round-trips have
# been verified.
NEXUS_ENABLE_AMAZON_PUBLISH=false
# How publishes behave when the flag is on. Default 'dry-run' so a
# fat-fingered enable doesn't immediately push to production.
#   dry-run  — log payload, write audit row, return synthetic success
#              (no HTTP call, no side effect)
#   sandbox  — real HTTP to sandbox.sellingpartnerapi-<region>.amazon.com
#   live     — real HTTP to sellingpartnerapi-<region>.amazon.com
AMAZON_PUBLISH_MODE=dry-run

# ── eBay Integration ───────────────────────────────────────────────
EBAY_CLIENT_ID=xxxxxxxxxxxxx
EBAY_CLIENT_SECRET=xxxxxxxxxxxxx
EBAY_REFRESH_TOKEN=xxxxxxxxxxxxx
EBAY_ENVIRONMENT=PRODUCTION

# ── eBay publish gating (C.7) ───────────────────────────────────────
# Master switch for the eBay listing publish path. Default false:
# every wizard /submit attempt for an eBay channel is logged in
# ChannelPublishAttempt with outcome='gated' and short-circuited
# before any HTTP. Set true once dryRun → sandbox round-trips have
# been verified.
NEXUS_ENABLE_EBAY_PUBLISH=false
# How publishes behave when the flag is on. Default 'dry-run' so a
# fat-fingered enable doesn't immediately push to production.
#   dry-run  — log payload, write audit row, return synthetic offerId
#              + listingId without HTTP
#   sandbox  — real HTTP to https://api.sandbox.ebay.com (operator
#              must mark a sandbox ChannelConnection active first;
#              prod connection's tokens won't work against sandbox)
#   live     — real HTTP to https://api.ebay.com (or EBAY_API_BASE
#              if explicitly overridden)
EBAY_PUBLISH_MODE=dry-run
EBAY_API_BASE=https://api.ebay.com
EBAY_AUTH_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_MARKETPLACE_ID=EBAY_IT
EBAY_CURRENCY=EUR
EBAY_MERCHANT_LOCATION_KEY=xavia-riccione-warehouse
EBAY_LOCATION_POSTAL_CODE=47838
EBAY_LOCATION_ADDRESS=

# ── AI Services ────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxxxxxxx

# ── Server Configuration ───────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Webhook Configuration ──────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RETRY_MAX_ATTEMPTS=3
WEBHOOK_RETRY_INITIAL_DELAY_MS=1000

# ── Sync Configuration ─────────────────────────────────────────────
SYNC_BATCH_SIZE=100
SYNC_TIMEOUT_MS=300000
SYNC_RETRY_MAX_ATTEMPTS=3
SYNC_RETRY_INITIAL_DELAY_MS=1000
SYNC_RETRY_MAX_DELAY_MS=32000
