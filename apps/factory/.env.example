# ── Nexus Factory OS (F1) — copy to .env; `npm run setup -w @nexus/factory` fills the generated values ──
# Names only in this template. NEVER commit real values; .env is gitignored repo-wide.

# SQLite file. Default (when unset): apps/factory/data/factory.db
FACTORY_DATABASE_URL=

# 64-char hex key for AES-256-GCM encryption of stored credentials (Google refresh
# token, Sendcloud keys). Generated by `npm run setup` if missing. Never printed.
FACTORY_ENCRYPTION_KEY=

# RBAC mode: shadow (log would-be denials, allow) | enforce. Default: shadow.
FACTORY_RBAC_MODE=shadow

# First-owner bootstrap (scripts/bootstrap-owner.ts reads these once; password
# may be omitted to be prompted interactively).
FACTORY_OWNER_EMAIL=
FACTORY_OWNER_INITIAL_PASSWORD=

# Google OAuth Desktop client (Settings › Integrations wizard also accepts these
# pasted in-app; env is optional convenience for dev).
FACTORY_GOOGLE_CLIENT_ID=
FACTORY_GOOGLE_CLIENT_SECRET=

# ── Feature gates ────────────────────────────────────────────────
# Bind 0.0.0.0 so shop-floor phones on the LAN can reach the app (F1 default: off)
FACTORY_LAN=0

# ── EPQ.5 — Italy/EU compliance ──────────────────────────────────
# Your own VAT number WITH country prefix (e.g. IT01234567890) — required for
# VIES checkVatApprox to mint a consultation number (art. 41 audit proof).
FACTORY_VAT_NUMBER=

# Stripe deposit-on-accept (D-1). BOTH must be set or the feature stays fully
# dark (no button, webhook 404s); bank-transfer instructions remain the
# always-on fallback (Quotes page › Legal gear).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
