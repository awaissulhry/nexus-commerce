{
  "name": "@nexus/factory",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n WEB,WORKER -c blue,green \"FACTORY_BUILD_DIR=.next-dev next dev -p 3100\" \"tsx watch worker/index.ts\" --kill-others-on-fail",
    "dev:web": "FACTORY_BUILD_DIR=.next-dev next dev -p 3100",
    "dev:worker": "tsx watch worker/index.ts",
    "build": "next build",
    "start": "concurrently -n WEB,WORKER -c blue,green \"next start -p 3100\" \"tsx worker/index.ts\"",
    "setup": "tsx scripts/setup.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset.ts",
    "fts:rebuild": "tsx scripts/fts-rebuild.ts",
    "bootstrap:owner": "tsx scripts/bootstrap-owner.ts",
    "test": "vitest run",
    "check:no-touch": "node scripts/no-touch-check.mjs",
    "check:rbac": "tsx scripts/check-rbac-coverage.ts",
    "check:ds-parity": "node scripts/ds-parity-check.mjs",
    "check:query-bounds": "node scripts/check-query-bounds.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tanstack/react-virtual": "^3.13.2",
    "better-sqlite3": "^12.4.1",
    "googleapis": "^144.0.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.10",
    "pdfkit": "^0.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.9.2",
    "sanitize-html": "^2.17.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.16.1",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.7",
    "prisma": "7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
