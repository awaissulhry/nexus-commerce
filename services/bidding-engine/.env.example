# --- Redis / queue ---
REDIS_URL=redis://localhost:6379
BIDDING_QUEUE=bidding-writes

# --- Primary Fastify app (internal REST; DB access goes through it) ---
PRIMARY_API_URL=https://nexusapi-production-b7bb.up.railway.app
# Shared secret presented as `x-internal-token` on every internal call.
PRIMARY_API_TOKEN=change-me

# --- Amazon Ads API (the worker performs the writes) ---
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
AMAZON_ADS_REGION=EU            # NA | EU | FE

# --- Throttling / concurrency ---
WORKER_CONCURRENCY=4            # parallel jobs across the worker
PROFILE_BUCKET_CAPACITY=10      # token-bucket burst per Amazon profile
PROFILE_BUCKET_REFILL_PER_SEC=8 # sustained writes/sec per profile

# --- Safety ---
# When 1, the worker computes + logs but never writes to Amazon.
BIDDING_DRY_RUN=1
HTTP_PORT=8081
LOG_LEVEL=info
