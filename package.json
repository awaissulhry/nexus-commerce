{
  "name": "nexus-commerce",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "cd packages/database && npx prisma migrate deploy && cd ../.. && node apps/api/dist/index.js",
    "start:api": "cd packages/database && npx prisma migrate deploy && cd ../.. && node apps/api/dist/index.js",
    "start:web": "cd apps/web && npm start",
    "check:drift": "npm run check:drift --workspace=@nexus/database"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5"
  }
}
