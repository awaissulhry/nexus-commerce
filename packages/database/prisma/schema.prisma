// P0 #27: Per-brand / per-marketplace terminology glossary fed into
// the AI listing-content generator. `brand = null` rows apply to
// every brand in the marketplace; `brand = "X"` rows narrow to brand X.
// `avoid` is the list of words the model keeps producing that the
// human seller doesn't want (Giubbotto vs Giacca for motorcycle
// jackets in IT, etc.).
model TerminologyPreference {
  id          String   @id @default(cuid())
  brand       String?
  marketplace String
  language    String
  preferred   String
  avoid       String[] @default([])
  context     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brand, marketplace])
  @@index([marketplace])
}

model MarketplaceSync {
  id             String   @id @default(cuid())
  product        Product  @relation(fields: [productId], references: [id])
  productId      String
  channel        String // e.g., 'AMAZON', 'EBAY'
  lastSyncStatus String // e.g., 'SUCCESS', 'FAILED', 'PENDING'
  lastSyncAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productId, channel])
}

model Channel {
  id        String    @id @default(cuid())
  type      String
  name      String
  // (was: credentials TEXT — dropped in 20260506_h2_unify_channel_connection
  //  because nothing in code referenced it and the table itself is empty.
  //  All connection credentials now live on ChannelConnection.)
  listings  Listing[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Listing {
  id           String   @id @default(cuid())
