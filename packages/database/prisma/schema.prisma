// ── Phase 2: Orders & Financials ────────────────────────────────────────

enum OrderChannel {
  AMAZON
  EBAY
  SHOPIFY
  WOOCOMMERCE
  ETSY
  MANUAL
}

enum OrderStatus {
  PENDING
  SHIPPED
  CANCELLED
  DELIVERED
}

model Order {
  id String @id @default(cuid())

  // ── Phase 26: Unified Order Command ──────────────────────────────────
  // Cross-channel order ingestion
  channel         OrderChannel
  // D.1: marketplace code (IT/DE/UK/GLOBAL/etc.) — nullable for legacy rows.
  marketplace     String?
  channelOrderId  String // Unique per channel
  status          OrderStatus  @default(PENDING)
  totalPrice      Decimal      @db.Decimal(12, 2)
  // D.1: per-order currency snapshot at import time. Falls back to EUR.
  currencyCode    String?      @default("EUR")
  customerName    String
  customerEmail   String
  shippingAddress Json // { street, city, state, postalCode, country }

  // D.1: Phase 28 — real customer-side timestamps. createdAt is the row
  // insert time (ingestion); these track the order's own lifecycle.
  purchaseDate DateTime?
  paidAt       DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?

  // D.1: FBA vs FBM (Amazon) or null for non-Amazon. Pulled from
  // SP-API FulfillmentChannel (AFN=FBA, MFN=FBM).
  fulfillmentMethod String?

  // Relations
  items                 OrderItem[]
  financialTransactions FinancialTransaction[]
  shipments             Shipment[]
  returns               Return[]
  reviewRequests        ReviewRequest[]
  tags                  OrderTag[]

  // Metadata
  amazonMetadata      Json?
  ebayMetadata        Json?
  shopifyMetadata     Json?
  woocommerceMetadata Json?
  etsyMetadata        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([channel, channelOrderId])
  @@index([channel])
  @@index([marketplace])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([purchaseDate])
  @@index([deliveredAt])
}

model OrderItem {
  id String @id @default(cuid())

  // Order Reference
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  // Product Reference
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?

  // ── Phase 26: Unified Order Item ────────────────────────────────────
  sku      String
  quantity Int
  price    Decimal @db.Decimal(10, 2)

  // Metadata
  amazonMetadata Json?
  ebayMetadata   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([sku])
}

// ── F.1: Daily Sales Aggregate ─────────────────────────────────────────────
// One row per (sku, channel, marketplace, day) — pre-aggregated demand
// signal that the replenishment algorithm reads from. Replaces live
// `OrderItem.groupBy` on the read path. Refreshed by a service that
// re-aggregates from OrderItem on a schedule + after every order write.
//
// Future SP-API report ingest (F.3) writes the same shape with `source`
// flipped to `AMAZON_REPORT` etc., overriding the OrderItem-derived
// numbers when reports land canonical figures (refunds, taxes, returns).
model DailySalesAggregate {
  id String @id @default(cuid())

  // ── Identity ────────────────────────────────────────────────────
  sku         String
  // OrderChannel as a string (AMAZON/EBAY/SHOPIFY/...) so SP-API report
  // ingest paths can write here without depending on the enum.
  channel     String
  // Country code (IT/DE/...) for region-scoped channels, GLOBAL for
  // single-store channels (Shopify, Etsy, WooCommerce). Mirrors the
  // ChannelListing.marketplace convention.
  marketplace String
  // Day key (DATE, no time component). Postgres `DATE` storage.
  day         DateTime @db.Date

  // ── Core demand metrics (always populated) ──────────────────────
  unitsSold    Int     @default(0)
  // Sum of OrderItem.price * quantity in the order's currency. For
  // multi-currency setups, the currency is tracked per source channel;
  // analytics that compare across marketplaces should normalize separately.
  grossRevenue Decimal @db.Decimal(14, 2) @default(0)
  // Distinct order count contributing to this row (units / orders =
  // average basket size for this SKU on this day).
  ordersCount  Int     @default(0)

  // ── F.3: SP-API report fields (nullable until reports land) ────
  // Populated by Amazon Sales & Traffic report (sessions, buy-box %,
  // conversion). Left null for OrderItem-derived rows.
  sessions            Int?
  buyBoxPct           Decimal? @db.Decimal(5, 2)
  conversionRate      Decimal? @db.Decimal(5, 4)
  // True if the SKU was out of stock at any point during the day.
  // Critical for the forecaster — zero sales due to no stock should
  // not lower the demand baseline.
  isStockOut          Boolean  @default(false)
  // ASP (average selling price) for the day. Helps detect price
  // changes that explain demand shifts.
  averageSellingPrice Decimal? @db.Decimal(10, 2)

  // ── Provenance ──────────────────────────────────────────────────
  // ORDER_ITEM | AMAZON_REPORT | EBAY_REPORT | SHOPIFY_REPORT | MANUAL
  // The forecaster prefers report-sourced rows when available; the
  // refresh service won't overwrite a higher-priority source with a
  // lower-priority one (see refreshSalesAggregates docstring).
  source String @default("ORDER_ITEM")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One row per identity tuple — upsert key. Source is intentionally
  // NOT in the unique because a SKU's day should resolve to a single
  // canonical aggregate; precedence is resolved at write time.
  @@unique([sku, channel, marketplace, day])
  @@index([sku, day])
  @@index([channel, marketplace, day])
  @@index([day])
}

// ── F.4: Replenishment forecast ────────────────────────────────────────────
// Per-(sku, channel, marketplace, day) demand prediction for the next 90
// days. Generated nightly by the forecast worker (Holt-Winters baseline +
// external signal multipliers). The replenishment endpoint sums the
// horizon window (today + leadTime + safetyDays) instead of doing live
// velocity math, which lets seasonality + retail events + weather
// elasticities flow through to the urgency calculation.
//
// Confidence bands (lower80 / upper80) come from Holt-Winters' built-in
// prediction intervals — UI shows "reorder 200 units (140-280 likely)"
// so the user understands when the model is uncertain.
model ReplenishmentForecast {
  id String @id @default(cuid())

  // ── Identity ────────────────────────────────────────────────────
  sku         String
  channel     String
  marketplace String
  // The day this forecast targets (UTC, no time component).
  horizonDay  DateTime @db.Date

  // ── Forecast values ─────────────────────────────────────────────
  // Point forecast in units. Always >= 0 (clamped at the source).
  forecastUnits Decimal @db.Decimal(12, 2)
  // 80% prediction interval. Lower can be 0 (clamped); upper bounds the
  // headroom the user might want to hold for tail demand.
  lower80       Decimal @db.Decimal(12, 2) @default(0)
  upper80       Decimal @db.Decimal(12, 2) @default(0)

  // ── Provenance / signals ────────────────────────────────────────
  // Which model generated this row. Lets future versions of the worker
  // (e.g. LightGBM v2) coexist with v1 baselines and lets the UI tag
  // forecasts with their generation. 'HOLT_WINTERS_V1' for v0.
  model       String @default("HOLT_WINTERS_V1")
  // Multiplicative factors that shaped the point forecast, kept for
  // transparency in the UI: { weather: 1.1, holiday: 1.5, retail: 2.0 }.
  // Default {} for forecasts with no external adjustment.
  signals     Json   @default("{}")
  // Free-form note; rows with sparse history get tagged 'COLD_START',
  // rows that fell back from Holt-Winters → trailing-mean get tagged
  // 'TRAILING_MEAN_FALLBACK', etc.
  generationTag String?

  // When this row was generated. Forecast workers always overwrite via
  // upsert — there's only ever one row per (sku, channel, marketplace,
  // horizonDay) regardless of how many times the worker has run.
  generatedAt DateTime @default(now())

  @@unique([sku, channel, marketplace, horizonDay])
  @@index([sku, horizonDay])
  @@index([channel, marketplace, horizonDay])
  @@index([horizonDay])
}

// ── F.4: Retail event calendar ──────────────────────────────────────────────
// Pre-known sales events that drive demand spikes (Prime Day, Black
// Friday, Italian saldi, EICMA, etc.). The forecast worker reads this
// table and applies expectedLift as a multiplicative factor on event
// days for the relevant scope (channel / marketplace / category).
//
// Seeded with a starter set in scripts/seed-retail-events.ts; sellers
// add to it as they hear about category-specific events. UI surfaces
// the next 3 events as banners on /fulfillment/replenishment with prep
// deadline = event_date - max(supplier_lead_times).
// ── F.6: Brand / company settings ─────────────────────────────────────────
// Single-row table for the seller's brand identity used on outbound
// artifacts: factory POs, packing slips, GTIN exemption letters, etc.
// Edited via /settings/company; rendered into PDF letterheads by the
// factory-po-pdf service. Seeded as a single empty row on first read so
// the GET endpoint never has to handle the missing-row case.
model BrandSettings {
  id String @id @default(cuid())

  // ── Company identity ────────────────────────────────────────────
  companyName        String?
  // Multi-line address rendered on the letterhead. JSON array of strings.
  // ["Via Aurelia 123", "00165 Roma RM", "Italia"] for Xavia.
  addressLines       String[] @default([])
  // VAT / partita IVA / tax ID — varies by jurisdiction; free-form.
  taxId              String?
  // Public-facing contact info on the PO header.
  contactEmail       String?
  contactPhone       String?
  websiteUrl         String?

  // ── Letterhead assets ───────────────────────────────────────────
  // Cloudinary or other hosted URL — pdfkit downloads + embeds at
  // render time. ~600×200 transparent PNG works best at letter size.
  logoUrl            String?

  // ── PDF defaults ────────────────────────────────────────────────
  // Free-form signature block, e.g. "Per: Awais Sulhry / Procurement".
  // Rendered above the signature line on factory POs.
  signatureBlockText String?
  // Default PO notes appended to every factory PO body. Sellers
  // override per-PO via the bulk-PO modal's notes field.
  defaultPoNotes     String?
  // Default sender line for emails to suppliers (display + email).
  // Future: when SES is wired this drives the From: header. v0
  // surfaces it for the user to copy into their mail client.
  factoryEmailFrom   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RetailEvent {
  id String @id @default(cuid())

  // ── Identity ────────────────────────────────────────────────────
  name        String
  // Inclusive event window. Single-day events have startDate == endDate.
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date

  // ── Scope (any/all may be null = applies broadly) ───────────────
  // null => applies to every channel
  channel     String?
  // null => applies to every marketplace under the channel
  marketplace String?
  // null => applies to every product type
  productType String?

  // ── Multiplier ──────────────────────────────────────────────────
  // Expected demand lift on event days. 1.0 = no lift; 4.0 = 4x typical.
  // Conservative defaults: Prime Day 3.0, Black Friday 4.0, Cyber
  // Monday 2.5, Italian saldi 1.4, EICMA 1.3. Sellers tune from data.
  expectedLift Decimal @db.Decimal(4, 2) @default(1)

  // Lead-time-aware reminder offset. UI uses this to surface
  // "Black Friday in 47 days — last day to PO: Oct 13". Optional;
  // default 30d for events that don't specify.
  prepLeadTimeDays Int @default(30)

  // ── Metadata ────────────────────────────────────────────────────
  description String?
  source      String? // 'AMAZON_OFFICIAL', 'CUSTOM', 'INDUSTRY_CAL'
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
  @@index([channel, marketplace])
  @@index([isActive])
}

model FinancialTransaction {
  id String @id @default(cuid())

  // Channel-specific Transaction IDs
  amazonTransactionId String? // Nullable for non-Amazon transactions
  ebayTransactionId   String? // eBay transaction ID

  // Order Reference
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  // Transaction Details
  transactionType String // "Order", "Refund", "FBA_Fee", "Shipping_Fee", "Tax", "Adjustment", "eBay_Fee", "PayPal_Fee"
  transactionDate DateTime

  // Financial Amounts
  amount       Decimal @db.Decimal(12, 2)
  currencyCode String  @default("USD")

  // Fee Breakdown
  amazonFee          Decimal @default(0) @db.Decimal(10, 2)
  fbaFee             Decimal @default(0) @db.Decimal(10, 2)
  paymentServicesFee Decimal @default(0) @db.Decimal(10, 2)
  ebayFee            Decimal @default(0) @db.Decimal(10, 2) // eBay final value fee
  paypalFee          Decimal @default(0) @db.Decimal(10, 2) // PayPal transaction fee
  otherFees          Decimal @default(0) @db.Decimal(10, 2)

  // Net Revenue Calculation
  grossRevenue Decimal @db.Decimal(12, 2)
  netRevenue   Decimal @db.Decimal(12, 2)

  // Status
  status String // "Pending", "Completed", "Reversed"

  // Metadata
  amazonMetadata Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([transactionType])
  @@index([transactionDate])
  @@index([status])
}

model ChannelConnection {
  id String @id @default(cuid())

  // Channel Type
  channelType String // "AMAZON", "EBAY", "SHOPIFY", "WOOCOMMERCE", "ETSY"

  // eBay OAuth2 Credentials
  ebayAccessToken    String? // Current access token
  ebayRefreshToken   String? // Refresh token (long-lived)
  ebayTokenExpiresAt DateTime? // Token expiration timestamp
  ebayDevId          String? // eBay Developer ID (from app)
  ebayAppId          String? // eBay App ID (from app)
  ebaySignInName     String? // eBay seller username
  ebayStoreName      String? // eBay store name
  ebayStoreFrontUrl  String? // eBay store URL

  // Connection Status
  isActive       Boolean   @default(false)
  lastSyncAt     DateTime?
  lastSyncStatus String? // "SUCCESS", "FAILED", "PARTIAL"
  lastSyncError  String?

  // Metadata
  connectionMetadata Json? // Additional eBay-specific data
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  variantListings VariantChannelListing[]

  @@index([channelType])
  @@index([isActive])
}

model OutboundSyncQueue {
  id String @id @default(cuid())

  // ── PHASE 9: Support both Product and ChannelListing changes ────
  // At least one must be set
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  channelListingId String?
  channelListing   ChannelListing? @relation(fields: [channelListingId], references: [id], onDelete: Cascade)

  offerId String?
  // Note: Offer doesn't have direct relation; tracked via channelListingId

  // ── Target channel ─────────────────────────────────────────────
  targetChannel SyncChannel @default(AMAZON)
  targetRegion  String? // e.g., "US", "DE" (for regional syncs)

  // ── Sync status ────────────────────────────────────────────────
  syncStatus OutboundSyncStatus @default(PENDING)

  // ── Payload (what to sync) ─────────────────────────────────────
  payload Json // { "price": 99.99, "quantity": 50, "title": "...", "offers": [...] }

  // ── Error tracking ─────────────────────────────────────────────
  errorMessage String?
  errorCode    String?
  retryCount   Int     @default(0)
  maxRetries   Int     @default(3)

  // ── Timestamps ─────────────────────────────────────────────────
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncedAt    DateTime? // When successfully synced
  nextRetryAt DateTime? // When to retry if failed

  // ── PHASE 12a: Grace Period (Undo Sync) ─────────────────────────
  // If set, Autopilot will not process this item until holdUntil <= NOW()
  // Allows 5-minute window to cancel syncs before they go live
  holdUntil DateTime? // Hold sync until this time (grace period)

  // ── Metadata ───────────────────────────────────────────────────
  syncType          String // "PRICE_UPDATE", "QUANTITY_UPDATE", "LISTING_SYNC", "OFFER_SYNC", "FULL_SYNC"
  externalListingId String? // Amazon ASIN or eBay ItemID

  @@index([productId])
  @@index([channelListingId])
  @@index([syncStatus])
  @@index([targetChannel])
  @@index([nextRetryAt])
}

// ── Phase 5: Bulk Operations Audit Log ───────────────────────────────
// Records every PATCH /api/products/bulk request for traceability.
// userId left nullable until auth is wired; populated as null for now.
model BulkOperation {
  id           String  @id @default(cuid())
  userId       String?
  productCount Int
  changeCount  Int
  changes      Json // [{ id, field, oldValue, newValue }]
  status       String // SUCCESS | PARTIAL | FAILED | PENDING_APPLY
  errors       Json? // [{ id, field, error }]

  // ── Phase D.3: Cascade audit ─────────────────────────────────────
  // How many cascade fan-outs this operation triggered (0 if no
  // cascade flags were set in the request).
  cascadeCount     Int      @default(0)
  // Product IDs of every child that was updated as a cascade target.
  // Useful for "undo" — replay these in reverse.
  affectedChildren String[] @default([])

  // ── Phase D.4: CSV/XLSX upload preview state ────────────────────
  // status='PENDING_APPLY' rows hold a parsed-and-validated upload
  // waiting on user confirmation; expiresAt clears stale rows.
  expiresAt      DateTime?
  completedAt    DateTime?
  uploadFilename String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([status])
  @@index([status, expiresAt])
}

// ── T.6: Bulk-ops templates ──────────────────────────────────────────
// Server-side replacement for the localStorage saved-views the bulk-
// ops grid used to ship with. Stores the full state needed to rebuild
// the grid: visible columns, filter dimensions, enabled channels, and
// enabled productTypes. Shared across the workspace today (no userId
// scoping yet) so teammates can share grid configurations; userId
// reserved for a future per-user / per-workspace scope.
model BulkOpsTemplate {
  id          String  @id @default(cuid())
  name        String
  description String?
  /**
   * Reserved — null today (workspace-shared). When set, scopes the
   * template to a specific user. Indexed so per-user lookups stay
   * cheap when scoping lands.
   */
  userId      String?

  /**
   * Column ids to render, in display order. Mirrors the existing
   * saved-views shape.
   */
  columnIds String[]

  /**
   * FilterState shape from apps/web/.../bulk-operations/lib/types.ts:
   * status[], channels[], stockLevel, productTypes[], parentage,
   * hasAsin, hasGtin, missingRequired. Stored as JSONB so the shape
   * can evolve without migrations.
   */
  filterState Json?

  /**
   * Channel + productType filters that drive the column registry —
   * separate from filterState because they affect WHICH fields are
   * fetched, not WHICH rows are visible.
   */
  enabledChannels     String[] @default([])
  enabledProductTypes String[] @default([])

  /**
   * W.10 — group keys collapsed in the band when the user saved the
   * template. Restored on load so the user's preferred density
   * survives.
   */
  collapsedGroups String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([updatedAt])
}

// ── Phase D.3f: Live category schema sync ────────────────────────────
// Cached snapshots of Amazon `getDefinitionsProductType` (and eventually
// eBay equivalents). One row per (channel, marketplace, productType,
// schemaVersion). The active row for a given (channel, marketplace,
// productType) is the most recently fetched one whose `expiresAt > now`
// AND `isActive`. Older rows are kept around so SchemaChange diffing
// has a previous version to compare against.
model CategorySchema {
  id               String   @id @default(cuid())
  channel          String
  // Nullable because some channels (eBay) may not be marketplace-scoped
  // at the schema level.
  marketplace      String?
  productType      String
  // Provider-supplied version identifier. For Amazon this is
  // `meta.version` from the response; lets us detect "schema changed"
  // without diffing the entire JSON blob.
  schemaVersion    String
  // The full provider response — JSON Schema with `properties`,
  // `required`, etc. Big (50–500KB) but TOASTed by Postgres.
  schemaDefinition Json
  // Variation themes block from the schema (Amazon: `variation_theme`
  // enum at the top level). Null if the type doesn't vary.
  variationThemes  Json?
  fetchedAt        DateTime @default(now())
  // 24h after fetchedAt by default — the service refreshes when
  // `now > expiresAt`. Manual force-refresh writes a new row.
  expiresAt        DateTime
  isActive         Boolean  @default(true)

  @@unique([channel, marketplace, productType, schemaVersion])
  @@index([channel, marketplace, productType])
  @@index([expiresAt])
}

// ── Phase 5.4: GTIN exemption submission package ────────────────────
// User-driven status flow with Amazon Seller Central handoff. Amazon
// has no SP-API endpoint for exemption submission; we generate the
// perfect submission package + track status the user reports back.
//
// Status transitions:
//   DRAFT          — user is filling out the form
//   PACKAGE_READY  — ZIP generated, instructions on screen
//   SUBMITTED      — user clicked "Mark as submitted" + optional caseId
//   APPROVED       — user reported Amazon's approval; cached for the
//                    brand + marketplace combo so future products
//                    auto-skip the wizard step
//   REJECTED       — user reported Amazon's rejection + reason
//   ABANDONED      — user cancelled before submitting
model GtinExemptionApplication {
  id          String   @id @default(cuid())
  brandName   String
  productIds  String[] // products this exemption covers
  marketplace String // IT | DE | FR | …
  // Phase K.7 — Amazon's exemption-grant page asks per (brand,
  // productType) so different categories can have independent
  // approval status. Nullable for backwards compat with rows
  // created before this column existed; null = "covers any
  // category for this brand+marketplace".
  productType String?

  // Brand verification path
  brandRegistrationType String // TRADEMARK | BRAND_STAND_IN | WEBSITE_ONLY
  trademarkNumber       String?
  trademarkCountry      String?
  trademarkDate         DateTime?
  trademarkCertUrl      String?
  brandWebsite          String?

  // Generated artifacts (the brand letter is stored as plain text and
  // re-rendered to PDF on each download — no external storage needed).
  brandLetter           String   @db.Text
  brandLetterCustomised Boolean  @default(false)
  imagesProvided        String[]
  // { passed: 7, failed: 2, items: [{ url, dimensions, issues, … }] }
  imageValidation       Json?

  // User-driven status
  status          String  @default("DRAFT")
  amazonCaseId    String? // user-pasted after Seller Central submit
  rejectionReason String? // user-pasted from Amazon's email

  createdAt          DateTime  @default(now())
  packageGeneratedAt DateTime?
  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([brandName])
  @@index([brandName, marketplace])
}

// ── Phase 5.3: Listing wizard ────────────────────────────────────────
// One row per (productId, channel, marketplace) wizard session.
// state holds the per-step JSON (see lib/wizard-state in apps/web).
// Status transitions: DRAFT → SUBMITTED → LIVE | FAILED. Future
// phases (5.4 / 5.5 / Phase 6) flesh out the per-step content; the
// shell here just persists progress so the user can resume.
// Phase A: multi-channel rebuild. Single (channel, marketplace) columns
// became a `channels` JSON array of { platform, marketplace } tuples,
// with companion `channelStates` for per-channel overrides + `submissions`
// for per-channel publish tracking. Resume key is now hashed-channels-set
// rather than a single channel pair.
model ListingWizard {
  id        String @id @default(cuid())
  productId String

  // [{platform: "AMAZON", marketplace: "IT"}, ...]. Order is the
  // user-selection order from Step 1. Hash below is order-insensitive
  // so resume keys stay stable if a user re-orders later.
  channels Json

  // md5 of the canonical (sorted) channels set. Indexed via the
  // unique constraint below.
  channelsHash String

  currentStep Int @default(1)

  // Shared state across all selected channels: identifiers,
  // gtinExemption, base values for attributes / content / pricing.
  // Image data lives in the ListingImage table (multi-scope).
  state Json @default("{}")

  // Per-channel overrides keyed by "PLATFORM:MARKET" (e.g. "AMAZON:DE").
  //   { "AMAZON:DE": { categories: {...}, attributes: {...}, ... } }
  channelStates Json @default("{}")

  // [{platform, marketplace, status, submissionId?, error?, ...}, ...].
  // One entry per (platform, marketplace) tuple after submit.
  submissions Json @default("[]")

  status String @default("DRAFT") // DRAFT | SUBMITTED | LIVE | FAILED

  // NN.1 — optimistic concurrency on wizard PATCHes. Two devices
  // editing the same wizard simultaneously each PATCH the version
  // they read; second one to land gets 409.
  version Int @default(1)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // NN.14 — soft expiry. DRAFT wizards >30 days are eligible for
  // cleanup. Set when the wizard is created so the cron job has a
  // simple WHERE clause.
  expiresAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channelsHash, status])
  @@index([productId])
  @@index([status])
  @@index([expiresAt])
}

// NN.4 — append-only audit log. One row per PATCH/PUT/DELETE on
// Product, ChannelListing, or ListingWizard. Records who, when,
// what changed (before/after JSON), source IP. Required for SOC 2
// + GDPR audit trails.
model AuditLog {
  id String @id @default(cuid())

  // Who. userId is nullable so system / cron writes can still log.
  userId String?
  ip     String?

  // What.
  entityType String // "Product" | "ChannelListing" | "ListingWizard" | ...
  entityId   String
  action     String // "create" | "update" | "delete" | "submit" | "replicate"

  // Before / after snapshots — diff lives in the audit viewer.
  // Cap: writers should slim these down to changed fields only,
  // not full row dumps, or the table balloons.
  before Json?
  after  Json?

  // Free-form metadata: which bulk-op id triggered this, which
  // marketplace context, which idempotency key, etc.
  metadata Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// Phase A: per-listing image set with multi-scope and variation-aware
// targeting. ProductImage stays as the master gallery (source of truth);
// ListingImage entries either reference a master image (via
// `sourceProductImageId`) or have their own uploads. Resolution at
// publish time cascades from most-specific (variant + marketplace) to
// most-general (no variant + GLOBAL).
model ListingImage {
  id          String  @id @default(cuid())
  productId   String
  variationId String? // NULL = product-level; set = variation-specific

  scope       ImageScope @default(GLOBAL)
  platform    String? // Required when scope ∈ {PLATFORM, MARKETPLACE}
  marketplace String? // Required when scope = MARKETPLACE

  url      String
  filename String?
  // 0-indexed, scoped to the (productId, variationId, scope, platform,
  // marketplace) bucket. Reorder writes are bulk-replace within bucket.
  position Int
  role     ImageRole @default(GALLERY)

  width              Int?
  height             Int?
  fileSize           Int?
  mimeType           String?
  hasWhiteBackground Boolean? // computed by validation service

  // When this image was copied from the master ProductImage gallery,
  // points back at the source. NULL for direct uploads.
  sourceProductImageId String?

  uploadedAt DateTime @default(now())
  uploadedBy String?

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variation ProductVariation? @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@index([productId, scope, platform, marketplace])
  @@index([productId, variationId, scope])
  @@index([productId, position])
}

enum ImageScope {
  GLOBAL // All channels, all variations within the variationId scope
  PLATFORM // Specific platform, all its markets
  MARKETPLACE // Specific platform + market combo
}

enum ImageRole {
  MAIN
  GALLERY
  INFOGRAPHIC
  LIFESTYLE
  SIZE_CHART
  SWATCH
}

// Append-only log of every detected schema change (added/removed
// fields, required-flag flips). Used to surface "Amazon changed X"
// notifications and identify products that may need attention.
model SchemaChange {
  id               String   @id @default(cuid())
  channel          String
  marketplace      String?
  productType      String
  // FIELD_ADDED | FIELD_REMOVED | FIELD_TYPE_CHANGED | REQUIRED_CHANGED
  changeType       String
  fieldId          String
  oldValue         Json?
  newValue         Json?
  detectedAt       DateTime @default(now())
  // Snapshot of product IDs in this catalog using `productType` at
  // detection time. Empty until we wire the lookup.
  affectedProducts String[] @default([])

  @@index([channel, marketplace, productType])
  @@index([detectedAt])
}

// ─────────────────────────────────────────────────────────────────────
// FULFILLMENT B.1 — domain spine for warehouse, shipments, returns,
// suppliers, POs, manufacturing, replenishment, stock movements.
// Single warehouse today (Italy) but modeled multi-warehouse-ready.
// Sendcloud is the carrier middleware; FBA is a distinct lane.
// ─────────────────────────────────────────────────────────────────────

enum StockMovementReason {
  ORDER_PLACED
  ORDER_CANCELLED
  ORDER_REFUNDED
  RETURN_RECEIVED
  RETURN_RESTOCKED
  INBOUND_RECEIVED
  SUPPLIER_DELIVERY
  MANUFACTURING_OUTPUT
  FBA_TRANSFER_OUT
  FBA_TRANSFER_IN
  MANUAL_ADJUSTMENT
  INVENTORY_COUNT
  WRITE_OFF
  RESERVATION_RELEASED
}

enum ShipmentStatusFBM {
  DRAFT
  READY_TO_PICK
  PICKED
  PACKED
  LABEL_PRINTED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RETURNED
}

enum ReturnStatusFlow {
  REQUESTED
  AUTHORIZED
  IN_TRANSIT
  RECEIVED
  INSPECTING
  RESTOCKED
  REFUNDED
  REJECTED
  SCRAPPED
}

enum ReturnConditionGrade {
  NEW
  LIKE_NEW
  GOOD
  DAMAGED
  UNUSABLE
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum WorkOrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InboundType {
  FBA
  SUPPLIER
  MANUFACTURING
  TRANSFER
}

enum InboundStatus {
  DRAFT
  IN_TRANSIT
  ARRIVED
  RECEIVING
  CLOSED
  CANCELLED
}

enum CarrierCode {
  SENDCLOUD
  AMAZON_BUY_SHIPPING
  MANUAL
}

enum ReplenishmentUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Warehouse {
  id           String  @id @default(cuid())
  code         String  @unique // e.g. "IT-MAIN"
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  postalCode   String?
  country      String  @default("IT")
  isDefault    Boolean @default(false)
  isActive     Boolean @default(true)

  // Sendcloud sender address mapping — Sendcloud uses sender_address_id
  sendcloudSenderId Int?

  stockMovements   StockMovement[]
  shipments        Shipment[]
  inboundShipments InboundShipment[]
  purchaseOrders   PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only audit trail for every stock change. Parent product totalStock
// is the running sum; balanceAfter is captured on each row for fast
// "what was stock at time T" queries without replaying.
model StockMovement {
  id            String              @id @default(cuid())
  productId     String
  variationId   String?
  warehouseId   String?
  change        Int // signed (+5 or -3)
  balanceAfter  Int
  reason        StockMovementReason
  // Polymorphic ref to whatever caused the movement
  referenceType String? // "Order" | "Return" | "InboundShipment" | "PurchaseOrder" | "WorkOrder" | "FBAShipment" | "Manual"
  referenceId   String?
  notes         String?
  actor         String? // userId or "system"
  createdAt     DateTime            @default(now())

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([productId, createdAt])
  @@index([variationId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([reason])
  @@index([referenceType, referenceId])
}

model Carrier {
  id                   String      @id @default(cuid())
  code                 CarrierCode @unique
  name                 String
  isActive             Boolean     @default(false)
  // Encrypted credentials JSON (AES-256-GCM, same pattern as MarketplaceCredential).
  // Sendcloud: { publicKey, privateKey, integrationId }
  credentialsEncrypted String?
  // Default Sendcloud shipping_method_id mapping per channel/marketplace
  defaultServiceMap    Json? // { "AMAZON_IT": 12345, "EBAY_IT": 67890, ... }
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

// Outbound shipment for FBM/eBay/Shopify/Woo/Etsy orders.
// One shipment can cover multiple OrderItems but is bound to one Order.
// FBA orders DO NOT use this — Amazon ships them.
model Shipment {
  id          String            @id @default(cuid())
  // D.1: real FK to Order (was previously a free-form string with no constraint).
  // SET NULL on order delete since shipments outlive orders for archival.
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId     String?
  warehouseId String?
  carrierCode CarrierCode       @default(SENDCLOUD)
  status      ShipmentStatusFBM @default(DRAFT)

  // Sendcloud parcel binding
  sendcloudParcelId String? @unique
  trackingNumber    String?
  trackingUrl       String?
  labelUrl          String?
  serviceCode       String? // e.g. "GLS_BusinessParcel" or Sendcloud method id
  serviceName       String?

  // Parcel measurements at pack time
  weightGrams Int?
  lengthCm    Decimal? @db.Decimal(10, 2)
  widthCm     Decimal? @db.Decimal(10, 2)
  heightCm    Decimal? @db.Decimal(10, 2)

  // Cost tracking (cents to avoid float drift)
  costCents    Int?
  currencyCode String? @default("EUR")

  // Lifecycle timestamps
  pickedAt       DateTime?
  packedAt       DateTime?
  labelPrintedAt DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?

  // Tracking pushback to channel — null until acked
  trackingPushedAt  DateTime?
  trackingPushError String?

  pickedBy String?
  packedBy String?

  notes   String?
  version Int     @default(1)

  warehouse Warehouse?     @relation(fields: [warehouseId], references: [id])
  items     ShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([carrierCode])
  @@index([trackingNumber])
  @@index([createdAt])
}

model ShipmentItem {
  id          String  @id @default(cuid())
  shipmentId  String
  orderItemId String?
  productId   String?
  sku         String
  quantity    Int

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([productId])
}

model Supplier {
  id              String  @id @default(cuid())
  name            String
  contactName     String?
  email           String?
  phone           String?
  addressLine1    String?
  city            String?
  postalCode      String?
  country         String? @default("IT")
  taxId           String? // partita IVA / VAT number
  paymentTerms    String? // e.g. "Net 30" / "30gg DF"
  defaultCurrency String? @default("EUR")
  leadTimeDays    Int     @default(14)
  isActive        Boolean @default(true)
  notes           String?

  products       SupplierProduct[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplierProduct {
  id                   String  @id @default(cuid())
  supplierId           String
  productId            String
  supplierSku          String?
  costCents            Int? // cost per unit in supplier's default currency
  currencyCode         String? @default("EUR")
  moq                  Int     @default(1) // minimum order quantity
  leadTimeDaysOverride Int?
  isPrimary            Boolean @default(false)

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, productId])
  @@index([productId])
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  poNumber             String              @unique
  supplierId           String?
  warehouseId          String?
  status               PurchaseOrderStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  totalCents           Int                 @default(0)
  currencyCode         String              @default("EUR")
  notes                String?
  createdBy            String?
  version              Int                 @default(1)

  supplier         Supplier?           @relation(fields: [supplierId], references: [id])
  warehouse        Warehouse?          @relation(fields: [warehouseId], references: [id])
  items            PurchaseOrderItem[]
  inboundShipments InboundShipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  supplierSku      String?
  sku              String
  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitCostCents    Int     @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
}

model InboundShipment {
  id        String        @id @default(cuid())
  type      InboundType
  status    InboundStatus @default(DRAFT)
  reference String? // free-form reference (supplier invoice #, transport doc, etc.)

  // Optional links — set whichever is relevant by `type`
  warehouseId     String?
  fbaShipmentId   String? // Amazon FBA shipment plan id (for type=FBA)
  purchaseOrderId String?
  workOrderId     String?
  asnNumber       String?

  expectedAt DateTime?
  arrivedAt  DateTime?
  closedAt   DateTime?

  notes   String?
  version Int     @default(1)

  warehouse     Warehouse?            @relation(fields: [warehouseId], references: [id])
  purchaseOrder PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  workOrder     WorkOrder?            @relation(fields: [workOrderId], references: [id])
  items         InboundShipmentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([fbaShipmentId])
}

model InboundShipmentItem {
  id                String  @id @default(cuid())
  inboundShipmentId String
  productId         String?
  sku               String
  quantityExpected  Int
  quantityReceived  Int     @default(0)
  qcStatus          String? // PASS | FAIL | HOLD
  qcNotes           String?

  inboundShipment InboundShipment @relation(fields: [inboundShipmentId], references: [id], onDelete: Cascade)

  @@index([inboundShipmentId])
  @@index([productId])
}

model WorkOrder {
  id          String          @id @default(cuid())
  productId   String
  quantity    Int
  status      WorkOrderStatus @default(PLANNED)
  startedAt   DateTime?
  completedAt DateTime?
  costCents   Int?
  notes       String?

  inboundShipments InboundShipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

model Return {
  id                 String                @id @default(cuid())
  // D.1: real FK to Order (was a free-form string).
  order              Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId            String?
  channel            String // AMAZON | EBAY | SHOPIFY | WOOCOMMERCE | ETSY
  marketplace        String?
  channelReturnId    String?
  rmaNumber          String?               @unique
  status             ReturnStatusFlow      @default(REQUESTED)
  reason             String?
  conditionGrade     ReturnConditionGrade?
  refundStatus       String                @default("PENDING") // PENDING | APPROVED | REFUNDED | REJECTED
  refundCents        Int?
  currencyCode       String                @default("EUR")
  // FBA returns are managed by Amazon — we mirror them read-only.
  isFbaReturn        Boolean               @default(false)
  // Restock policy snapshot at receipt time
  restockChannel     String?
  restockWarehouseId String?
  // Lifecycle
  receivedAt         DateTime?
  inspectedAt        DateTime?
  refundedAt         DateTime?
  restockedAt        DateTime?
  notes              String?
  version            Int                   @default(1)

  items ReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([channel])
  @@index([isFbaReturn])
}

model ReturnItem {
  id             String                @id @default(cuid())
  returnId       String
  orderItemId    String?
  productId      String?
  sku            String
  quantity       Int
  conditionGrade ReturnConditionGrade?
  notes          String?

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([productId])
}

model ReplenishmentRule {
  id                  String  @id @default(cuid())
  productId           String  @unique
  // Manual overrides (otherwise computed from velocity)
  minStock            Int? // floor — alert fires below this
  reorderPoint        Int? // override the auto reorder point
  reorderQuantity     Int? // override the auto reorder quantity
  safetyStockDays     Int     @default(7)
  // Where to reorder from
  preferredSupplierId String?
  isManufactured      Boolean @default(false) // if true, generate WorkOrder instead of PO
  isActive            Boolean @default(true)
  notes               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([preferredSupplierId])
}

// ─────────────────────────────────────────────────────────────────────
// PRODUCTS REBUILD C.1 — Tags, Bundles, SavedView
// ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductTag[]
  orders   OrderTag[]
}

model ProductTag {
  productId String
  tagId     String
  createdAt DateTime @default(now())

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([productId])
  @@index([tagId])
}

model Bundle {
  id                String   @id @default(cuid())
  productId         String   @unique
  name              String
  description       String?
  computedCostCents Int      @default(0)
  isActive          Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  components BundleComponent[]
}

model BundleComponent {
  id            String @id @default(cuid())
  bundleId      String
  productId     String
  quantity      Int    @default(1)
  unitCostCents Int?

  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  surface   String   @default("products")
  name      String
  filters   Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, surface, name])
  @@index([userId, surface])
}

// ─────────────────────────────────────────────────────────────────────
// ORDERS REBUILD D.1 — review request engine + tags
// ─────────────────────────────────────────────────────────────────────

enum ReviewRequestStatus {
  ELIGIBLE // matched a rule, ready to send
  SCHEDULED // queued for the next worker tick
  SENT // request delivered to channel
  SUPPRESSED // skipped due to exclusion (return, refund, age window, etc.)
  FAILED // channel API returned an error
  SKIPPED // manually skipped by operator
}

enum ReviewRuleScope {
  AMAZON_PER_MARKETPLACE
  AMAZON_GLOBAL
  EBAY
  SHOPIFY
  WOOCOMMERCE
  ETSY
  MANUAL
}

model ReviewRequest {
  id                   String              @id @default(cuid())
  orderId              String
  channel              String // AMAZON | EBAY | SHOPIFY | WOOCOMMERCE | ETSY | MANUAL
  marketplace          String?
  status               ReviewRequestStatus @default(ELIGIBLE)
  // When the worker should attempt the send (post-delivery + ruleSendDelayDays)
  scheduledFor         DateTime?
  sentAt               DateTime?
  // Channel-specific tracking — Amazon Solicitations API returns a Request-Id
  // on success; we persist for audit + dedup.
  providerRequestId    String?
  providerResponseCode String?
  errorMessage         String?
  suppressedReason     String?
  // Which rule matched (null for manual one-off sends from the detail page)
  ruleId               String?

  order Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rule  ReviewRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dedup: at most one request row per (orderId, channel) — the rules engine
  // checks for an existing row before inserting a new one.
  @@unique([orderId, channel])
  @@index([status])
  @@index([scheduledFor])
  @@index([sentAt])
}

model ReviewRule {
  id                   String          @id @default(cuid())
  name                 String
  scope                ReviewRuleScope
  // For AMAZON_PER_MARKETPLACE rules — which marketplace this rule binds to.
  // Null for AMAZON_GLOBAL or single-store channels.
  marketplace          String?
  isActive             Boolean         @default(true)
  // Day window relative to deliveredAt. Amazon Solicitations requires
  // 4–30 days; we expose minDays/maxDays so users can tighten it.
  minDaysSinceDelivery Int             @default(7)
  maxDaysSinceDelivery Int             @default(25)
  // Exclusions encoded as a stable string set:
  //   "has_active_return"  | "has_refund" | "has_negative_message"
  //   "low_value_order"    | "fba_only"   | "fbm_only"
  exclusions           String[]        @default([])
  // Optional: only apply to orders >= this gross
  minOrderTotalCents   Int?
  // Snapshot of who created the rule (single-tenant: "default-user")
  createdBy            String?
  notes                String?

  requests ReviewRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, scope, marketplace])
  @@index([scope, isActive])
}

model OrderTag {
  orderId   String
  tagId     String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([orderId, tagId])
  @@index([orderId])
  @@index([tagId])
}
