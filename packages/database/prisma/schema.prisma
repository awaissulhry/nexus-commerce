// ── Settings & Configuration (Phase 6) ────────────────────────────────────

model AccountSettings {
  id           String   @id @default(cuid())
  businessName String   @default("")
  addressLine1 String   @default("")
  addressLine2 String   @default("")
  city         String   @default("")
  state        String   @default("")
  postalCode   String   @default("")
  country      String   @default("US")
  timezone     String   @default("America/New_York")
  currency     String   @default("USD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NotificationPreference {
  id        String  @id @default(cuid())
  eventType String // NEW_ORDER, LOW_STOCK, RETURN_REQUEST, SYNC_FAILURE, AI_COMPLETE
  email     Boolean @default(true)
  sms       Boolean @default(false)
  inApp     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventType])
}

model ApiKey {
  id        String    @id @default(cuid())
  label     String
  keyHash   String // SHA-256 hash of the key
  keyPrefix String // First 8 chars for display (e.g., "nxk_abc1...")
  lastUsed  DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserProfile {
  id          String   @id @default(cuid())
  displayName String   @default("")
  email       String   @default("")
  avatarUrl   String   @default("")
  // Password stored as bcrypt hash
  passwordHash String  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Webhook Event Tracking ─────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(cuid())
  channel     String // SHOPIFY, WOOCOMMERCE, ETSY
  eventType   String // product/update, inventory/update, order/create, etc.
  externalId  String // Unique ID from marketplace (for idempotency)
  payload     Json // Raw webhook payload
  signature   String? // Webhook signature for verification
  isProcessed Boolean  @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([channel, externalId])
  @@index([isProcessed])
  @@index([channel])
}

// ── Marketplace Credentials ────────────────────────────────────────

model MarketplaceCredential {
  id              String   @id @default(cuid())
  channel         String // SHOPIFY, WOOCOMMERCE, ETSY
  credentialType  String // ACCESS_TOKEN, REFRESH_TOKEN, API_KEY, API_SECRET, WEBHOOK_SECRET
  encryptedValue  String // AES-256-GCM encrypted
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([channel, credentialType])
  @@index([channel])
}

// ── Rate Limit Tracking ────────────────────────────────────────────

model RateLimitLog {
  id           String   @id @default(cuid())
  channel      String // SHOPIFY, WOOCOMMERCE, ETSY
  endpoint     String // API endpoint being rate limited
  requestCount Int      @default(0)
  resetAt      DateTime // When the rate limit window resets
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([channel, endpoint, resetAt])
  @@index([channel])
  @@index([resetAt])
}

// ── Amazon Catalog Sync Logging ─────────────────────────────────────────

model SyncLog {
  id                String    @id @default(cuid())
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId         String
  
  syncType          String    // "AMAZON_CATALOG", "AMAZON_INVENTORY", "AMAZON_PRICING"
  status            String    // "PENDING", "IN_PROGRESS", "SUCCESS", "FAILED"
  
  itemsProcessed    Int       @default(0)
  itemsSuccessful   Int       @default(0)
  itemsFailed       Int       @default(0)
  
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  
  errorMessage      String?
  details           Json?     // Detailed sync results
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([productId])
  @@index([status])
  @@index([syncType])
}

// ── Sync Error Tracking ────────────────────────────────────────────

model SyncError {
  id          String   @id @default(cuid())
  channel     String // SHOPIFY, WOOCOMMERCE, ETSY
  errorType   String // RATE_LIMIT, AUTHENTICATION, VALIDATION, NETWORK, etc.
  errorMessage String
  errorStack  String?
  context     Json? // Additional context (product ID, variant ID, etc.)
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  nextRetryAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel])
  @@index([errorType])
  @@index([nextRetryAt])
  @@index([resolvedAt])
}

// ── Phase 2: Orders & Financials ────────────────────────────────────────

enum OrderChannel {
  AMAZON
  EBAY
  SHOPIFY
}

enum OrderStatus {
  PENDING
  SHIPPED
  CANCELLED
  DELIVERED
}

model Order {
  id                    String    @id @default(cuid())
  
  // ── Phase 26: Unified Order Command ──────────────────────────────────
  // Cross-channel order ingestion
  channel               OrderChannel
  channelOrderId        String    // Unique per channel
  status                OrderStatus @default(PENDING)
  totalPrice            Decimal   @db.Decimal(12, 2)
  customerName          String
  customerEmail         String
  shippingAddress       Json      // { street, city, state, postalCode, country }
  
  // Relations
  items                 OrderItem[]
  financialTransactions FinancialTransaction[]
  
  // Metadata
  amazonMetadata        Json?
  ebayMetadata          Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@unique([channel, channelOrderId])
  @@index([channel])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id                    String    @id @default(cuid())
  
  // Order Reference
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId               String
  
  // Product Reference
  product               Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId             String?
  
  // ── Phase 26: Unified Order Item ────────────────────────────────────
  sku                   String
  quantity              Int
  price                 Decimal   @db.Decimal(10, 2)
  
  // Metadata
  amazonMetadata        Json?
  ebayMetadata          Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([orderId])
  @@index([productId])
  @@index([sku])
}

model FinancialTransaction {
  id                    String    @id @default(cuid())
  
  // Channel-specific Transaction IDs
  amazonTransactionId   String?   // Nullable for non-Amazon transactions
  ebayTransactionId     String?   // eBay transaction ID
  
  // Order Reference
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId               String
  
  // Transaction Details
  transactionType       String    // "Order", "Refund", "FBA_Fee", "Shipping_Fee", "Tax", "Adjustment", "eBay_Fee", "PayPal_Fee"
  transactionDate       DateTime
  
  // Financial Amounts
  amount                Decimal   @db.Decimal(12, 2)
  currencyCode          String    @default("USD")
  
  // Fee Breakdown
  amazonFee             Decimal   @db.Decimal(10, 2)  @default(0)
  fbaFee                Decimal   @db.Decimal(10, 2)  @default(0)
  paymentServicesFee    Decimal   @db.Decimal(10, 2)  @default(0)
  ebayFee               Decimal   @db.Decimal(10, 2)  @default(0)  // eBay final value fee
  paypalFee             Decimal   @db.Decimal(10, 2)  @default(0)  // PayPal transaction fee
  otherFees             Decimal   @db.Decimal(10, 2)  @default(0)
  
  // Net Revenue Calculation
  grossRevenue          Decimal   @db.Decimal(12, 2)
  netRevenue            Decimal   @db.Decimal(12, 2)
  
  // Status
  status                String    // "Pending", "Completed", "Reversed"
  
  // Metadata
  amazonMetadata        Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([orderId])
  @@index([transactionType])
  @@index([transactionDate])
  @@index([status])
}

model ChannelConnection {
  id                    String    @id @default(cuid())
  
  // Channel Type
  channelType           String    // "AMAZON", "EBAY", "SHOPIFY", "WOOCOMMERCE", "ETSY"
  
  // eBay OAuth2 Credentials
  ebayAccessToken       String?   // Current access token
  ebayRefreshToken      String?   // Refresh token (long-lived)
  ebayTokenExpiresAt    DateTime? // Token expiration timestamp
  ebayDevId             String?   // eBay Developer ID (from app)
  ebayAppId             String?   // eBay App ID (from app)
  ebaySignInName        String?   // eBay seller username
  ebayStoreName         String?   // eBay store name
  ebayStoreFrontUrl     String?   // eBay store URL
  
  // Connection Status
  isActive              Boolean   @default(false)
  lastSyncAt            DateTime?
  lastSyncStatus        String?   // "SUCCESS", "FAILED", "PARTIAL"
  lastSyncError         String?
  
  // Metadata
  connectionMetadata    Json?     // Additional eBay-specific data
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  variantListings       VariantChannelListing[]
  
  @@index([channelType])
  @@index([isActive])
}

model OutboundSyncQueue {
  id                String              @id @default(cuid())
  
  // ── PHASE 9: Support both Product and ChannelListing changes ────
  // At least one must be set
  productId         String?
  product           Product?            @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  channelListingId  String?
  channelListing    ChannelListing?     @relation(fields: [channelListingId], references: [id], onDelete: Cascade)
  
  offerId           String?
  // Note: Offer doesn't have direct relation; tracked via channelListingId
  
  // ── Target channel ─────────────────────────────────────────────
  targetChannel     SyncChannel         @default(AMAZON)
  targetRegion      String?             // e.g., "US", "DE" (for regional syncs)
  
  // ── Sync status ────────────────────────────────────────────────
  syncStatus        OutboundSyncStatus  @default(PENDING)
  
  // ── Payload (what to sync) ─────────────────────────────────────
  payload           Json                // { "price": 99.99, "quantity": 50, "title": "...", "offers": [...] }
  
  // ── Error tracking ─────────────────────────────────────────────
  errorMessage      String?
  errorCode         String?
  retryCount        Int                 @default(0)
  maxRetries        Int                 @default(3)
  
  // ── Timestamps ─────────────────────────────────────────────────
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  syncedAt          DateTime?           // When successfully synced
  nextRetryAt       DateTime?           // When to retry if failed
  
  // ── PHASE 12a: Grace Period (Undo Sync) ─────────────────────────
  // If set, Autopilot will not process this item until holdUntil <= NOW()
  // Allows 5-minute window to cancel syncs before they go live
  holdUntil         DateTime?           // Hold sync until this time (grace period)
  
  // ── Metadata ───────────────────────────────────────────────────
  syncType          String              // "PRICE_UPDATE", "QUANTITY_UPDATE", "LISTING_SYNC", "OFFER_SYNC", "FULL_SYNC"
  externalListingId String?             // Amazon ASIN or eBay ItemID
  
  @@index([productId])
  @@index([channelListingId])
  @@index([syncStatus])
  @@index([targetChannel])
  @@index([nextRetryAt])
}

// ── Phase 5: Bulk Operations Audit Log ───────────────────────────────
// Records every PATCH /api/products/bulk request for traceability.
// userId left nullable until auth is wired; populated as null for now.
model BulkOperation {
  id           String   @id @default(cuid())
  userId       String?
  productCount Int
  changeCount  Int
  changes      Json     // [{ id, field, oldValue, newValue }]
  status       String   // SUCCESS | PARTIAL | FAILED
  errors       Json?    // [{ id, field, error }]
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([status])
}

