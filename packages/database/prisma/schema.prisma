// ── Pricing Rules ──────────────────────────────────────────────────────────

model PricingRule {
  id          String  @id @default(cuid())
  name        String
  type        String // MATCH_LOW, PERCENTAGE_BELOW, COST_PLUS_MARGIN, FIXED_PRICE, DYNAMIC_MARGIN
  description String? // Human-readable rule description

  // ── Priority & Execution (Phase 1 Enhancement) ──────────────────
  // Lower priority number = higher precedence (0 = highest)
  priority Int @default(100)

  // ── Margin Thresholds (Phase 1 Enhancement) ──────────────────────
  // Minimum acceptable margin percentage (e.g., 15 for 15%)
  minMarginPercent Decimal? @db.Decimal(5, 2)
  // Maximum acceptable margin percentage (e.g., 50 for 50%)
  maxMarginPercent Decimal? @db.Decimal(5, 2)

  // ── Rule Configuration ───────────────────────────────────────────
  parameters Json // Rule-specific config
  isActive   Boolean @default(true)

  // ── Relations ────────────────────────────────────────────────────
  products   PricingRuleProduct[]
  variations PricingRuleVariation[]

  // ── Audit Trail ──────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRuleProduct {
  id        String      @id @default(cuid())
  rule      PricingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId    String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@unique([ruleId, productId])
  @@index([ruleId])
  @@index([productId])
}

// ── Pricing Rule Variation Mapping (Phase 1 Enhancement) ──────────────
// Links pricing rules to specific product variations for granular control

model PricingRuleVariation {
  id          String           @id @default(cuid())
  rule        PricingRule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ruleId      String
  variation   ProductVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  variationId String

  @@unique([ruleId, variationId])
  @@index([ruleId])
  @@index([variationId])
}

// ── Sync Health & Logging (Phase 1 Enhancement) ────────────────────────────
// Tracks failed imports, conflict resolutions, and duplicate variation errors per channel

model SyncHealthLog {
  id String @id @default(cuid())

  // ── Identification ───────────────────────────────────────────────────
  channel   String // AMAZON, EBAY, SHOPIFY, WOOCOMMERCE, ETSY
  syncJobId String? // Reference to the sync job that triggered this log

  // ── Error Classification ─────────────────────────────────────────────
  errorType String // IMPORT_FAILED, CONFLICT_DETECTED, DUPLICATE_VARIATION, VALIDATION_ERROR, MAPPING_ERROR, RATE_LIMIT, AUTHENTICATION_ERROR
  severity  String @default("WARNING") // INFO, WARNING, ERROR, CRITICAL

  // ── Entity References ────────────────────────────────────────────────
  productId   String? // Reference to Product if applicable
  product     Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  variationId String? // Reference to ProductVariation if applicable
  variation   ProductVariation? @relation(fields: [variationId], references: [id], onDelete: SetNull)

  // ── Error Details ────────────────────────────────────────────────────
  errorMessage String // Human-readable error message
  errorDetails Json? // Detailed error context (stack trace, API response, etc.)

  // ── Conflict Resolution ──────────────────────────────────────────────
  conflictType     String? // PRICE_MISMATCH, INVENTORY_MISMATCH, ATTRIBUTE_MISMATCH, DUPLICATE_SKU, DUPLICATE_ASIN
  conflictData     Json? // Data about the conflict (e.g., {"local": {...}, "remote": {...}})
  resolutionStatus String  @default("UNRESOLVED") // UNRESOLVED, AUTO_RESOLVED, MANUAL_RESOLVED, IGNORED
  resolutionNotes  String? // Notes on how the conflict was resolved

  // ── Duplicate Variation Tracking ─────────────────────────────────────
  duplicateVariationIds String[] // Array of variation IDs that are duplicates

  // ── Audit Trail ──────────────────────────────────────────────────────
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime? // When the issue was resolved

  @@index([channel])
  @@index([errorType])
  @@index([severity])
  @@index([productId])
  @@index([variationId])
  @@index([resolutionStatus])
  @@index([createdAt])
}

// ── Bulk Action Queuing (Phase 1 Enhancement) ──────────────────────────────
// Tracks asynchronous bulk actions (Pricing, Inventory, Status) with progress tracking

model BulkActionJob {
  id String @id @default(cuid())

  // ── Job Identification ───────────────────────────────────────────────
  jobName    String // User-friendly name for the bulk action
  actionType String // PRICING_UPDATE, INVENTORY_UPDATE, STATUS_UPDATE, ATTRIBUTE_UPDATE, LISTING_SYNC
  channel    String? // Target channel (null = all channels)

  // ── Scope & Targeting ────────────────────────────────────────────────
  targetProductIds   String[] // Array of product IDs to process
  targetVariationIds String[] // Array of variation IDs to process (if empty, applies to all variations)
  filters            Json? // Query filters for dynamic targeting (e.g., {"status": "ACTIVE", "stock": {"lt": 10}})

  // ── Action Configuration ─────────────────────────────────────────────
  actionPayload Json // The actual changes to apply (structure depends on actionType)
  // Example for PRICING_UPDATE: {"priceAdjustment": 5.00, "adjustmentType": "FIXED"}
  // Example for INVENTORY_UPDATE: {"quantityChange": -10, "reason": "Manual adjustment"}
  // Example for STATUS_UPDATE: {"newStatus": "INACTIVE"}

  // ── Progress Tracking ────────────────────────────────────────────────
  status          String @default("PENDING") // PENDING, QUEUED, IN_PROGRESS, COMPLETED, FAILED, PARTIALLY_COMPLETED, CANCELLED
  totalItems      Int    @default(0) // Total items to process
  processedItems  Int    @default(0) // Items successfully processed
  failedItems     Int    @default(0) // Items that failed
  skippedItems    Int    @default(0) // Items skipped (e.g., already in desired state)
  progressPercent Int    @default(0) // 0-100

  // ── Error Handling ───────────────────────────────────────────────────
  errorLog  Json? // Array of errors encountered: [{"itemId": "...", "error": "...", "timestamp": "..."}]
  lastError String? // Most recent error message

  // ── Rollback Support ─────────────────────────────────────────────────
  isRollbackable Boolean @default(true) // Can this job be rolled back?
  rollbackJobId  String? // Reference to rollback job if one was created
  rollbackData   Json? // Snapshot of original values for rollback

  // ── Execution Details ────────────────────────────────────────────────
  createdBy   String? // User ID who created the job
  createdAt   DateTime  @default(now())
  startedAt   DateTime? // When processing began
  completedAt DateTime? // When processing finished
  updatedAt   DateTime  @updatedAt

  // ── Per-item state (Commit 2 of bulk-ops rebuild) ────────────────────
  // Foundation for retry of failed items, partial rollback, and
  // conflict detection. Cascaded on delete.
  items BulkActionItem[]

  @@index([actionType])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@index([completedAt])
}

// ── BulkActionItem ─────────────────────────────────────────────────────────
//
// One row per item processed by a BulkActionJob. The polymorphic target
// columns (productId / variationId / channelListingId) match the job's
// actionType target entity per the ACTION_ENTITY map in
// bulk-action.service.ts. Exactly one of the three is set per row.
//
// `beforeState` / `afterState` are slim diffs (changed fields only) — the
// foundation for partial rollback (Commit 12) and conflict detection
// (Commit 18). The errorLog JSON column on BulkActionJob is still written
// for backward compat; this table is the canonical per-item record going
// forward.

model BulkActionItem {
  id String @id @default(cuid())

  jobId String
  job   BulkActionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Polymorphic target. No FK constraints — preserves audit history
  // when the underlying entity is deleted (same pattern as AuditLog).
  productId        String?
  variationId      String?
  channelListingId String?

  status String @default("PENDING") // PENDING | SUCCEEDED | FAILED | SKIPPED

  errorMessage String?
  beforeState  Json?
  afterState   Json?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([jobId])
  @@index([jobId, status])
  @@index([productId])
}

