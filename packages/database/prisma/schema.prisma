generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FulfillmentMethod {
  FBA
  FBM
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REFUNDED
  DENIED
}

enum CampaignType {
  SP // Sponsored Products
  SB // Sponsored Brands
  SD // Sponsored Display
}

enum CampaignStatus {
  ENABLED
  PAUSED
  ARCHIVED
}

enum ShipmentStatus {
  WORKING
  SHIPPED
  IN_TRANSIT
  RECEIVING
  CLOSED
}

enum SyncChannel {
  AMAZON
  EBAY
  SHOPIFY
  WOOCOMMERCE
}

enum OutboundSyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  SKIPPED
}

enum PricingRuleType {
  FIXED
  MATCH_AMAZON
  PERCENT_OF_MASTER
}

model Product {
  id                String  @id @default(cuid())
  sku               String  @unique
  name              String
  basePrice         Decimal @db.Decimal(10, 2)
  totalStock        Int     @default(0)
  lowStockThreshold Int     @default(10) // Phase 23.2: Alert threshold for low-stock situations

  // Marketplace mapping (parent-level: non-buyable parent ASIN, shared eBay listing ID)
  amazonAsin           String?
  ebayItemId           String?
  ebayTitle            String?
  shopifyProductId     String?
  woocommerceProductId Int?

  // Identifiers (used for standalone products with no variations)
  upc          String?
  ean          String?
  brand        String?
  manufacturer String?

  // Physical attributes (defaults — variants can override)
  weightValue Decimal? @db.Decimal(10, 3)
  weightUnit  String? // e.g., 'lb', 'kg', 'oz'
  dimLength   Decimal? @db.Decimal(10, 2)
  dimWidth    Decimal? @db.Decimal(10, 2)
  dimHeight   Decimal? @db.Decimal(10, 2)
  dimUnit     String? // e.g., 'in', 'cm'

  // Content (shared/inherited by all variants)
  description  String? // D.5: HTML body shown on listings (master-level)
  bulletPoints String[] // Amazon-style bullet points
  aPlusContent Json? // Rich text / A+ Content as JSON
  keywords     String[] // Search keywords

  // Fulfillment (default — variants can override)
  fulfillmentMethod FulfillmentMethod? // FBA or FBM

  // ── NEW: Variation theme (Rithum pattern) ────────────────────────────
  // Defines which attributes create the variation matrix.
  // null = standalone product (parent is the purchasable SKU).
  // Examples: "Size", "Color", "SizeColor", "SizeColorMaterial"
  variationTheme String?

  // ── NEW: Product status ──────────────────────────────────────────────
  status String @default("ACTIVE") // DRAFT, ACTIVE, INACTIVE

  // ── NEW: Dynamic PIM Fields (Phase 7) ─────────────────────────────
  // Amazon product type (e.g., "LUGGAGE", "OUTERWEAR", "ELECTRONICS")
  productType String?

  // Flexible JSON storage for category-specific attributes
  // Structure: { "voltage": "110V", "apparel_size": "M", "material": "Cotton" }
  categoryAttributes Json?

  // Pricing intelligence
  costPrice       Decimal? @db.Decimal(10, 2) // Cost of goods for margin calc
  minMargin       Decimal? @db.Decimal(5, 2) // Minimum acceptable margin percentage (e.g., 15 for 15%)
  minPrice        Decimal? @db.Decimal(10, 2) // Pricing floor
  maxPrice        Decimal? @db.Decimal(10, 2) // Pricing ceiling
  buyBoxPrice     Decimal? @db.Decimal(10, 2) // Current Buy Box price
  competitorPrice Decimal? @db.Decimal(10, 2) // Lowest competitor price

  // Inventory intelligence
  firstInventoryDate DateTime? // For aging calculations

  // B2B pricing
  b2bPrice  Decimal? @db.Decimal(10, 2) // Business pricing
  b2bMinQty Int? // Minimum B2B quantity

  // ── Parent/Child Hierarchy (Amazon Catalog Sync) ─────────────────
  isParent Boolean   @default(false) // TRUE if this is a master parent
  parentId String? // Self-relation: parent product ID
  parent   Product?  @relation("ProductHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Product[] @relation("ProductHierarchy") // Child variations

  // ── Amazon Parent ASIN (non-buyable) ────────────────────────────
  parentAsin String? // Parent ASIN from Amazon (non-buyable)

  // ── Fulfillment Channel ─────────────────────────────────────────
  fulfillmentChannel FulfillmentMethod? // FBA or FBM (default for all variations)

  // ── Shipping Template (FBM only) ────────────────────────────────
  shippingTemplate String? // e.g., "Xavia FBM Shipping Template"

  // ── Sync Metadata ───────────────────────────────────────────────
  lastAmazonSync   DateTime?
  amazonSyncStatus String? // SUCCESS, FAILED, PENDING
  amazonSyncError  String?

  // ── PHASE 9: Master Catalog Metadata ──────────────────────────────
  // Indicates this is a master product (not a variation)
  isMasterProduct Boolean @default(true)

  // Master product reference (for variations)
  masterProductId  String?
  masterProduct    Product?  @relation("MasterVariations", fields: [masterProductId], references: [id], onDelete: Cascade)
  masterVariations Product[] @relation("MasterVariations")

  // ── PHASE D.3: Bulk-ops cascade + master-level GTIN ──────────────
  // Tracks which fields on this row were inherited from a parent
  // cascade. Updated by PATCH /api/products/bulk when cascade=true.
  cascadedFields String[] @default([])
  // Master-level GTIN for products without variations (Amazon accepts
  // GTIN at master OR variant level). Per-variant GTIN lives on
  // ProductVariation.gtin.
  gtin           String?

  // ── PHASE 31: PIM Master Catalog Fields ──────────────────────────
  // True master entity flag (vs. isMasterProduct which is legacy)
  isMaster          Boolean   @default(false)
  // Internal master SKU (separate from channel SKUs)
  masterSku         String?
  // Variation axes for master products: ["Color", "Size", "BodyType"]
  variationAxes     String[]  @default([])
  // Channels this master is currently linked to (resolved listings)
  linkedToChannels  String[]  @default([])
  // Where this product came from
  importSource      String? // "AMAZON_AUTO_IMPORT" | "MANUAL" | "CSV_UPLOAD"
  importedAt        DateTime?
  // Review workflow state
  reviewStatus      String? // "PENDING_REVIEW" | "APPROVED" | "MERGED"
  // For child products: per-variant attribute values
  // Example: {"Color": "Black", "Size": "M", "BodyType": "Men"}
  variantAttributes Json?

  // ── PHASE 20: SSOT Indicators ────────────────────────────────────
  // Track which channels this product is synced to
  syncChannels String[] @default([]) // ["AMAZON", "EBAY", "SHOPIFY"]

  // Overall validation state for this product
  validationStatus String   @default("VALID") // VALID, WARNING, ERROR
  validationErrors String[]

  // Track if this product has any channel-specific overrides
  hasChannelOverrides Boolean @default(false)

  // Last time any channel override was modified
  lastChannelOverrideAt DateTime?

  // Relations
  variations           ProductVariation[]
  images               ProductImage[]
  listingImages        ListingImage[] // Phase A: per-listing image set (multi-scope)
  listingWizards       ListingWizard[] // Phase A: multi-channel wizards for this product
  channelListings      ChannelListing[]
  channelListingImages ChannelListingImage[]
  listings             Listing[]
  draftListings        DraftListing[] // Phase 5: AI Listing Generator
  stockLogs            StockLog[]
  marketplaceSyncs     MarketplaceSync[]
  fbaShipmentItems     FBAShipmentItem[]
  pricingRuleProducts  PricingRuleProduct[]
  syncHealthLogs       SyncHealthLog[]
  syncLogs             SyncLog[]
  orderItems           OrderItem[] // Phase 2: Orders & Financials
  outboundSyncQueue    OutboundSyncQueue[] // Phase 8: Outbound Sync Engine

  // NN.1 — optimistic concurrency. Bumped on every PATCH/PUT.
  // Clients send the version they read; server rejects with 409 if
  // it advanced (someone else edited concurrently).
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gtin])
}

model ProductVariation {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  sku       String  @unique // Child SKU (unique, purchasable)

  // ── Multi-axis variation attributes (Rithum pattern) ──────────────
  // Replaces single name/value. Example: {"Color": "Black", "Size": "10"}
  variationAttributes Json?

  // ── PHASE 30: Reactive Attribute Inheritance ──────────────────────
  // Tracks which attributes are locked (not inherited from parent)
  // Structure: { "Color": true, "Material": false } means Color is locked, Material inherits
  lockedAttributes Json? @default("{}")

  // Legacy single-axis fields (kept for backward compat, deprecated)
  name  String? // e.g., 'Color', 'Size'
  value String? // e.g., 'Red', 'XL'

  // ── Pricing (always per-variant) ──────────────────────────────────
  price     Decimal  @db.Decimal(10, 2)
  costPrice Decimal? @db.Decimal(10, 2) // Cost of goods
  minPrice  Decimal? @db.Decimal(10, 2) // Repricing floor
  maxPrice  Decimal? @db.Decimal(10, 2) // Repricing ceiling
  mapPrice  Decimal? @db.Decimal(10, 2) // Minimum Advertised Price

  // ── Inventory (always per-variant) ────────────────────────────────
  stock Int @default(0)

  // ── Stock Buffer (hide stock when low) ────────────────────────────
  // When stock falls below this threshold, the product is hidden from listings
  // Useful for preventing overselling or managing low-stock situations
  stockBuffer Int @default(0)

  // ── Per-variant identifiers ───────────────────────────────────────
  upc  String?
  ean  String?
  gtin String?

  // ── Per-variant physical attributes (override parent defaults) ────
  weightValue Decimal? @db.Decimal(10, 3)
  weightUnit  String?
  dimLength   Decimal? @db.Decimal(10, 2)
  dimWidth    Decimal? @db.Decimal(10, 2)
  dimHeight   Decimal? @db.Decimal(10, 2)
  dimUnit     String?

  // ── Per-variant fulfillment ───────────────────────────────────────
  fulfillmentMethod FulfillmentMethod?

  // ── Per-variant marketplace IDs ───────────────────────────────────
  amazonAsin             String? // Child ASIN (buyable)
  ebayVariationId        String? // eBay variation identifier
  shopifyVariantId       String? // Shopify variant ID
  woocommerceVariationId Int? // WooCommerce variation ID
  etsyListingId          String? // Etsy listing ID
  etsySku                String? // Etsy SKU

  // ── Per-variant images ────────────────────────────────────────────
  images        VariantImage[]
  // Phase A: per-listing image set, scoped by GLOBAL/PLATFORM/MARKETPLACE
  // and optionally tied to this specific variation. ProductImage stays
  // as the master gallery; ListingImage is the per-listing surface.
  listingImages ListingImage[]

  // ── Per-variant channel listings ──────────────────────────────────
  channelListings VariantChannelListing[]

  // ── Sync Health Logs ─────────────────────────────────────────────
  syncHealthLogs SyncHealthLog[]

  // ── Marketplace-specific metadata (Phase 1 Enhancement) ────────────
  // Stores marketplace-specific traits: Amazon Browse Nodes, eBay Item Specifics, etc.
  // Example: {
  //   "amazon": {
  //     "browseNodeId": "123456",
  //     "browseNodePath": ["Electronics", "Computers", "Laptops"],
  //     "bulletPoints": ["Feature 1", "Feature 2"],
  //     "searchTerms": ["keyword1", "keyword2"]
  //   },
  //   "ebay": {
  //     "itemSpecifics": {"Brand": "Sony", "Color": "Black"},
  //     "categoryId": "15687",
  //     "conditionId": "3000"
  //   },
  //   "shopify": {
  //     "tags": ["tag1", "tag2"],
  //     "vendor": "Vendor Name"
  //   }
  // }
  marketplaceMetadata Json?

  // ── Status ────────────────────────────────────────────────────────
  isActive Boolean @default(true)

  // ── Pricing Rules (Phase 1 Enhancement) ──────────────────────────
  pricingRules PricingRuleVariation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// ── Variant-specific images ───────────────────────────────────────────────

model VariantImage {
  id        String           @id @default(cuid())
  variant   ProductVariation @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String
  url       String
  alt       String?
  type      String // MAIN, SWATCH, ALT, LIFESTYLE
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([variantId])
}

// ── Per-variant channel listing ───────────────────────────────────────────

model VariantChannelListing {
  id        String           @id @default(cuid())
  variant   ProductVariation @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String
  channelId String? // References Channel.id (legacy)

  // eBay Connection Reference
  channelConnection   ChannelConnection? @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  channelConnectionId String?

  // Channel Type
  channel String? // "AMAZON", "EBAY", "SHOPIFY", etc.

  // E.1 — Per-marketplace identity. Country code ("IT", "DE", "FR", ...) for
  // region-scoped channels, or "GLOBAL" for single-store channels. The same
  // (variantId, channel) pair can have multiple rows — one per marketplace —
  // each with its own channelProductId (child ASIN), channelSku, price, qty.
  marketplace String @default("GLOBAL")

  // Channel-specific SKU and IDs
  channelSku        String? // SKU as known by the channel
  channelProductId  String? // Channel-specific ID (child ASIN, eBay variation spec)
  externalListingId String? // eBay ItemID (12-digit number)
  externalSku       String? // eBay custom SKU

  // Pricing & Inventory
  channelPrice    Decimal  @db.Decimal(10, 2)
  channelQuantity Int      @default(0)
  currentPrice    Decimal? @db.Decimal(10, 2) // Alternative price field
  quantity        Int? // Alternative quantity field
  quantitySold    Int      @default(0)

  // Listing Details
  channelCategoryId String?
  listingStatus     String  @default("PENDING") // PENDING, ACTIVE, INACTIVE, ERROR, ENDED, UNSOLD, SOLD
  listingUrl        String?

  // Sync Tracking
  channelSpecificData Json? // Any channel-specific fields
  lastSyncedAt        DateTime?
  lastSyncStatus      String? // SUCCESS, FAILED, PENDING
  syncRetryCount      Int       @default(0)
  lastSyncError       String?

  @@unique([variantId, channelId])
  @@unique([variantId, channel, marketplace])
  @@index([variantId])
  @@index([channelId])
  @@index([channelConnectionId])
  @@index([externalListingId])
  @@index([marketplace])
  @@index([channel, marketplace, listingStatus])
}

// ── PHASE 9: Channel Listing (Platform-Specific Data) ──────────────────────

model ChannelListing {
  id String @id @default(cuid())

  // ── Master Product Reference ────────────────────────────────────
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  // ── Phase 23.2: Stock Buffer (Overselling Protection) ──────────
  // Units to reserve; marketplace sees (actualStock - stockBuffer)
  stockBuffer Int @default(0)

  // ── Channel & Market Identification ─────────────────────────────
  // Examples: "AMAZON_US", "AMAZON_DE", "EBAY_US", "EBAY_DE", "SHOPIFY", etc.
  channelMarket String // Composite key: CHANNEL_REGION (legacy)
  channel       String // "AMAZON", "EBAY", "SHOPIFY", "WOOCOMMERCE", "ETSY"
  region        String // "US", "DE", "UK", "FR", "JP", etc.
  // Phase 31b: clean per-marketplace key alongside legacy channelMarket.
  // Values: country code ("IT", "DE", "FR", ...) for region-scoped channels,
  // or "GLOBAL" for single-store channels (Shopify, WooCommerce, Etsy).
  marketplace   String @default("DEFAULT")

  // ── Platform-Specific Identifiers ───────────────────────────────
  // Amazon: Parent ASIN (non-buyable) or child ASIN (buyable)
  // eBay: ItemID (12-digit number)
  // Shopify: Product ID
  externalListingId String?
  externalParentId  String? // For Amazon parent ASIN

  // ── PHASE 15: Analytics Grouping Key ────────────────────────────
  // For Amazon: ASIN (groups FBA/FBM under single ASIN for analytics)
  // For eBay: ItemID (groups variations under single listing)
  // For Shopify: Product ID (groups variants)
  platformProductId String? // Analytics grouping key

  // ── Platform-Specific Title & Description ──────────────────────
  // Can differ from master product name
  title       String?
  description String? // HTML or plain text

  // ── Platform-Specific Pricing ──────────────────────────────────
  // Overrides master basePrice if set
  price     Decimal? @db.Decimal(10, 2)
  salePrice Decimal? @db.Decimal(10, 2)

  // ── PHASE 28: Pricing Rules & Adjustments ──────────────────────
  pricingRule            PricingRuleType @default(FIXED) // FIXED, MATCH_AMAZON, PERCENT_OF_MASTER
  priceAdjustmentPercent Decimal?        @db.Decimal(5, 2) // For PERCENT_OF_MASTER rule (e.g., 10 for +10%)

  // ── Platform-Specific Inventory ────────────────────────────────
  // Overrides master totalStock if set
  quantity Int?

  // ── Platform-Specific Attributes ───────────────────────────────
  // JSON structure varies by platform:
  // Amazon: { browseNodeId, bulletPoints, searchTerms, aplus_content }
  // eBay: { itemSpecifics, categoryId, conditionId, returnPolicy }
  // Shopify: { tags, vendor, collections }
  platformAttributes Json?

  // ── PHASE 12b: Variation Matrix ────────────────────────────────
  // Platform-specific variation theme (e.g., "Size", "Color", "SizeColor")
  // Defines how child products are grouped into multi-variant listings
  variationTheme   String?
  // Mapping of master variant attributes to platform-specific formatting
  // Example: { "Size": "SizeMap", "Color": "ColorMap" }
  variationMapping Json?

  // ── Listing Status & Sync Tracking ─────────────────────────────
  listingStatus  String    @default("DRAFT") // DRAFT, ACTIVE, INACTIVE, ENDED, ERROR
  lastSyncedAt   DateTime?
  lastSyncStatus String? // SUCCESS, FAILED, PENDING
  lastSyncError  String?
  syncRetryCount Int       @default(0)

  // ── Sync Control Flags ─────────────────────────────────────────
  // When true, next sync will pull from master product
  syncFromMaster Boolean @default(false)
  // When true, this listing is locked from syncing
  syncLocked     Boolean @default(false)

  // ── PHASE 15: Publishing Control ────────────────────────────────
  // Master toggle: when false, this listing will not sync to the platform
  isPublished Boolean @default(true)

  // ── PHASE 20: SSOT Override Toggles ────────────────────────────
  // When true, use master product value; when false, use channel-specific override
  followMasterTitle        Boolean @default(true)
  followMasterDescription  Boolean @default(true)
  followMasterPrice        Boolean @default(true)
  followMasterQuantity     Boolean @default(true)
  followMasterImages       Boolean @default(true)
  followMasterBulletPoints Boolean @default(true)

  // ── PHASE 20: SSOT Master Data References ──────────────────────
  // Store master values for quick comparison and cascade logic
  masterTitle        String?
  masterDescription  String?
  masterPrice        Decimal? @db.Decimal(10, 2)
  masterQuantity     Int?
  masterBulletPoints String[]

  // ── PHASE 20: Channel-Specific Overrides ───────────────────────
  // These are the actual values used when followMaster* = false
  titleOverride        String?
  descriptionOverride  String?
  priceOverride        Decimal? @db.Decimal(10, 2)
  quantityOverride     Int?
  bulletPointsOverride String[]

  // ── PHASE 20: Sync Status Tracking ────────────────────────────
  // Real-time sync state for this specific channel listing
  syncStatus      String    @default("IDLE") // IDLE, PENDING, SYNCING, IN_SYNC, FAILED
  syncRetryLastAt DateTime?

  // ── PHASE 20: Validation State ───────────────────────────────
  // Track validation errors per channel
  validationStatus String   @default("VALID") // VALID, WARNING, ERROR
  validationErrors String[]

  // ── PHASE 20: Audit Trail ────────────────────────────────────
  // Track when overrides were last modified
  lastOverrideAt DateTime?
  lastOverrideBy String? // User ID or system identifier

  // ── Relations ───────────────────────────────────────────────────
  offers            Offer[]
  images            ChannelListingImage[]
  outboundSyncQueue OutboundSyncQueue[]
  overrideHistory   ChannelListingOverride[]

  // NN.1 — optimistic concurrency on per-channel listing edits.
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, channelMarket])
  @@unique([productId, channel, marketplace], name: "productId_channel_marketplace")
  @@index([productId])
  @@index([channel])
  @@index([region])
  @@index([marketplace])
  @@index([externalListingId])
  @@index([listingStatus])
  @@index([syncStatus])
  @@index([validationStatus])
  @@index([channel, marketplace, listingStatus])
}

// ── Phase 31b: Marketplace lookup ──────────────────────────────────────────
// Static reference data: which (channel, code) pairs are valid for listings,
// plus their localization metadata. Seeded via seed-marketplaces.ts.
model Marketplace {
  id            String  @id @default(cuid())
  channel       String // "AMAZON" | "EBAY" | "SHOPIFY" | "WOOCOMMERCE" | "ETSY"
  code          String // "IT" | "DE" | "FR" | "GLOBAL" | ...
  name          String // "Amazon Italy"
  marketplaceId String? // SP-API marketplace ID e.g. "APJ6JRA9NG5V4"
  region        String // "EU" | "NA" | "FE" | "GLOBAL"
  currency      String // "EUR" | "GBP" | "USD"
  language      String // "it" | "de" | "fr" | "en"
  domainUrl     String? // "amazon.it" | "ebay.de"
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, code])
  @@index([channel])
}

// ── PHASE 20: Channel Listing Override (Audit Trail) ──────────────────────

model ChannelListingOverride {
  id String @id @default(cuid())

  // ── Channel Listing Reference ──────────────────────────────────
  channelListing   ChannelListing @relation(fields: [channelListingId], references: [id], onDelete: Cascade)
  channelListingId String

  // ── Override Field & Values ────────────────────────────────────
  // Which field was overridden (e.g., "price", "title", "description")
  fieldName     String
  // Previous value (before override)
  previousValue String?
  // New value (after override)
  newValue      String?
  // Whether this override is currently active
  isActive      Boolean @default(true)

  // ── Audit Information ──────────────────────────────────────────
  // User or system that made the change
  changedBy String?
  // Reason for the override
  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelListingId])
  @@index([fieldName])
  @@index([isActive])
}

// ── PHASE 9: Offer (Fulfillment-Specific SKU & Pricing) ──────────────────

model Offer {
  id String @id @default(cuid())

  // ── Channel Listing Reference ──────────────────────────────────
  channelListing   ChannelListing @relation(fields: [channelListingId], references: [id], onDelete: Cascade)
  channelListingId String

  // ── Fulfillment Method ─────────────────────────────────────────
  // "FBA" (Fulfillment by Amazon), "FBM" (Fulfilled by Merchant), etc.
  fulfillmentMethod FulfillmentMethod

  // ── Offer-Specific SKU ─────────────────────────────────────────
  // Different SKU per fulfillment method (e.g., "PRODUCT-FBA" vs "PRODUCT-FBM")
  sku String

  // ── Offer-Specific Pricing ─────────────────────────────────────
  // Overrides channel listing price if set
  price Decimal? @db.Decimal(10, 2)

  // ── Offer-Specific Inventory ──────────────────────────────────
  // Overrides channel listing quantity if set
  quantity Int?

  // ── Offer Status ───────────────────────────────────────────────
  isActive Boolean @default(true)

  // ── Offer-Specific Metadata ────────────────────────────────────
  // FBA: { shipmentId, fcCode, prepRequired }
  // FBM: { shippingTemplate, handlingTime, shippingCost }
  offerMetadata Json?

  // ── Sync Tracking ──────────────────────────────────────────────
  lastSyncedAt   DateTime?
  lastSyncStatus String?
  lastSyncError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelListingId, fulfillmentMethod])
  @@index([channelListingId])
  @@index([fulfillmentMethod])
  @@index([isActive])
}

// ── PHASE 9: Channel Listing Image (Platform-Specific Images) ──────────────

model ChannelListingImage {
  id String @id @default(cuid())

  // ── Can link to either Master Product OR Channel Listing ────────
  // If productId is set: master image (inherited by all listings)
  // If channelListingId is set: platform-specific image override
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String?

  channelListing   ChannelListing? @relation(fields: [channelListingId], references: [id], onDelete: Cascade)
  channelListingId String?

  // ── Image Data ─────────────────────────────────────────────────
  url       String
  alt       String?
  type      String // "MAIN", "ALT", "LIFESTYLE", "SWATCH"
  sortOrder Int     @default(0)

  // ── Platform-Specific Metadata ────────────────────────────────
  // Amazon: { asin, imageType }
  // eBay: { pictureURL, galleryType }
  platformMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([channelListingId])
}

model ProductImage {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  url       String
  alt       String?
  type      String // 'MAIN', 'ALT', 'LIFESTYLE'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

